# xdns (change nameservers to 1.0.0.1)
function xdns() {
    echo "nameserver 1.0.0.1" | sudo tee /run/resolvconf/resolv.conf \
    /run/resolvconf/interface/systemd-resolved /dev/null 2>&1
}

# zdns (change nameservers to 127.0.0.1)
function zdns() {
    echo "nameserver 127.0.0.1" | sudo tee /run/resolvconf/resolv.conf \
    /run/resolvconf/interface/systemd-resolved /dev/null 2>&1
}

