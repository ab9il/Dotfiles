# search with ripgrep-all and fzf
function rgf() {
	RG_PREFIX="rga --files-with-matches"
	local file
	file="$(
		FZF_DEFAULT_COMMAND="$RG_PREFIX '$1'" \
			fzf --sort \
                --preview="[[ ! -z {} ]] && rga --pretty --context 3 {q} {}" \
				--phony -q "$1" \
				--bind "change:reload:$RG_PREFIX {q}" \
				--preview-window="60%:wrap"
	)" &&
	echo "opening $file" &&
	xdg-open "$file"
}

# search with ripgrep-all
function rgg() {
[[ -z "$1" ]] || rga --pretty --context 3 "$1"
}

# generate some passwords
function mkpw() {
    for k in {1..5}; do
    < /dev/urandom tr -cd "[:print:]" | tr -d ' \\/\`\|' | head -c 22; echo
    done
}

# run Python in the virtual environment
python3() {
    # Check if the virtual environment is already active
    if [ -z "$VIRTUAL_ENV" ] || [ "$VIRTUAL_ENV" != "$HOME/.venv" ]; then
        # Activate the virtual environment if not already active
        if [ -f "$HOME/.venv/bin/activate" ]; then
            source "$HOME/.venv/bin/activate"
        else
            echo "Error: Virtual environment not found at $HOME/.venv"
            return 1
        fi
    fi
    # Now run the original python3 command
    command python3 "$@"
}

